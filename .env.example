# =============================================================================
# Universidade Dataweb — variáveis de ambiente
# Copie para `.env.local` e preencha. `.env*.local` é gitignored.
# =============================================================================

# --- Backoffice (operador) ---------------------------------------------------
# Senha única do backoffice (/admin/login). Default em dev: "dataweb".
ADMIN_PASSWORD=

# --- Supabase ----------------------------------------------------------------
# URL e chave pública (anon). Seguras para o client SE o RLS estiver ativo.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave de SERVICE ROLE: ignora o RLS. NUNCA exponha no client.
# Use somente no servidor (rotinas administrativas, emissão de certificado).
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# Variáveis usadas APENAS pelo docker-compose.yml (deploy via Docker/Traefik).
# No servidor, defina-as num arquivo `.env` ao lado do docker-compose.yml.
# =============================================================================

# Nome lógico do serviço (usado em container_name).
SERVICE_FULLNAME=universidade
# Tag da imagem a ser construída/publicada.
SERVICE_IMAGEVERSION=latest

# --- Traefik (roteamento) ----------------------------------------------------
# Identificador do serviço nos routers do Traefik.
TRAEFIK_SERVICE_FULLNAME=universidade
# Regra de host(s). Ex.: Host(`universidade.dw.net.br`)
TRAEFIK_ALL_HOSTNAMES=Host(`universidade.exemplo.com.br`)
